---
import { getCollection } from 'astro:content';
import Default from '../layouts/Default.astro';
import SectionCard from '../components/section/SectionCard.astro';
import ArticleCard from '../components/article/ArticleCard.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const sections = await getCollection('section');
  const articles = await getCollection('article');

  const sectionsRoute = sections.map((section) => {
    return {
      params: {
        slug: section.id,
      },
      props: { type: 'section', section },
    };
  });
  const articlesRoute = articles.map((article) => {
    return {
      params: {
        slug: article.id,
      },
      props: { type: 'article', article },
    };
  });

  return [...sectionsRoute, ...articlesRoute];
}

interface Props {
  section: CollectionEntry<'section'>;
  article: CollectionEntry<'article'>;
  type: 'section' | 'article';
}

const { section, article, type } = Astro.props;
---

<Default>
  {
    type === 'section' ? (
      <SectionCard section={section} />
    ) : (
      <ArticleCard article={article} />
    )
  }
</Default>
